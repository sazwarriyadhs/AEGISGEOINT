// D:\AegisGeoInt\frontend\src\components\CommandCenter\AegisMap.jsx
import React, { useEffect, useState } from 'react';
import { MapContainer, TileLayer, WMSTileLayer, Marker, Popup, ZoomControl } from 'react-leaflet';
import L from 'leaflet';
import 'leaflet/dist/leaflet.css';
import axios from 'axios';

// ============================================
// IMPORT ICONS DARI PUBLIC FOLDER
// ============================================
import droneIconUrl from '/icon_drone.png';
import logoUrl from '/logo.png';

// Fix Leaflet default icons
delete L.Icon.Default.prototype._getIconUrl;
L.Icon.Default.mergeOptions({
  iconRetinaUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon-2x.png',
  iconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-icon.png',
  shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
});

// ============================================
// BASE MAP OPTIONS
// ============================================
const BASEMAPS = {
  // Satellite - ESRI World Imagery (Best quality)
  satellite: {
    url: 'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
    attribution: '&copy; ESRI, DigitalGlobe, GeoEye, i-cubed, USDA, USGS, AEX, Getmapping, Aerogrid, IGN, IGP, swisstopo, and the GIS User Community'
  },
  // Satellite - Google Maps style (via Google tiles)
  googleSatellite: {
    url: 'https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}',
    attribution: '&copy; Google'
  },
  // Hybrid - Satellite with labels
  hybrid: {
    url: 'https://mt1.google.com/vt/lyrs=y&x={x}&y={y}&z={z}',
    attribution: '&copy; Google'
  },
  // Dark mode - for night operations
  dark: {
    url: 'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
    attribution: '&copy; OpenStreetMap, CartoDB'
  },
  // OpenStreetMap
  osm: {
    url: 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    attribution: '&copy; OpenStreetMap contributors'
  }
};

// ============================================
// CUSTOM DRONE ICON
// ============================================
const createDroneIcon = (status = 'active') => {
  const colors = {
    active: '#4caf50',
    warning: '#ffc107',
    critical: '#ef5350',
    idle: '#8899aa'
  };
  
  const color = colors[status] || '#4fc3f7';
  
  return L.divIcon({
    
    html: `
      <div style="
        position: relative;
        width: 32px;
        height: 32px;
      ">
        <img 
          src="${droneIconUrl}" 
          style="
            width: 32px;
            height: 32px;
            object-fit: contain;
            filter: drop-shadow(0 0 15px ${color}80);
            animation: drone-float 2s ease-in-out infinite;
          "
        />
        <div style="
          position: absolute;
          bottom: -4px;
          right: -4px;
          width: 10px;
          height: 10px;
          background: ${color};
          border-radius: 50%;
          border: 2px solid white;
          box-shadow: 0 0 10px ${color}80;
        "></div>
      </div>
    `,
    iconSize: [32, 32],
    iconAnchor: [16, 16],
    className: 'drone-marker-container'
  });
};

// ============================================
// THREAT ICON
// ============================================
const getThreatIcon = (level) => {
  const colors = {
    'HIGH': '#ef4444',
    'MEDIUM': '#f59e0b',
    'LOW': '#22c55e',
    'CRITICAL': '#dc2626'
  };
  const color = colors[level] || '#6b7280';
  
  return L.divIcon({
    className: 'threat-marker',
    html: `
      <div style="
        width: ${level === 'HIGH' || level === 'CRITICAL' ? 18 : 14}px;
        height: ${level === 'HIGH' || level === 'CRITICAL' ? 18 : 14}px;
        background: ${color};
        border-radius: 50%;
        border: 3px solid white;
        box-shadow: 0 0 20px ${color}80, inset 0 0 10px ${color}40;
        animation: threat-pulse 1.5s ease-in-out infinite;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 8px;
        font-weight: bold;
        color: white;
      ">
        ${level === 'HIGH' || level === 'CRITICAL' ? '!' : ''}
      </div>
    `,
    iconSize: [18, 18],
    iconAnchor: [9, 9]
  });
};

// ============================================
// SENSOR ICON
// ============================================
const sensorIcon = L.divIcon({
  className: 'sensor-marker',
  html: `
    <div style="
      width: 12px;
      height: 12px;
      background: #4fc3f7;
      border-radius: 50%;
      border: 2px solid white;
      box-shadow: 0 0 15px #4fc3f780;
      animation: sensor-pulse 2s ease-in-out infinite;
    "></div>
  `,
  iconSize: [12, 12],
  iconAnchor: [6, 6]
});

// ============================================
// ADD ANIMATION STYLES
// ============================================
const styles = `
  @keyframes drone-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-6px) rotate(5deg); }
  }
  
  @keyframes threat-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.3); opacity: 0.8; }
  }
  
  @keyframes sensor-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
  }
  
  .drone-marker-container {
    background: transparent !important;
    border: none !important;
  }
`;

// ============================================
// MAIN COMPONENT
// ============================================
const AegisMap = () => {
  const [trackedObjects, setTrackedObjects] = useState([]);
  const [sensors, setSensors] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [basemap, setBasemap] = useState('satellite'); // Default: satellite
  const [mapCenter] = useState([-2.54, 140.71]);
  const [mapZoom] = useState(11);

  // Fetch data dari GeoServer
  const fetchData = async () => {
    try {
      setError(null);
      
      const objectsRes = await axios.get(
        'http://localhost:8089/geoserver/aegisgeoint/wfs',
        {
          params: {
            service: 'WFS',
            version: '1.0.0',
            request: 'GetFeature',
            typeName: 'aegisgeoint:papua_tracked_objects',
            outputFormat: 'application/json'
          },
          timeout: 10000
        }
      );
      setTrackedObjects(objectsRes.data.features || []);
      
      const sensorsRes = await axios.get(
        'http://localhost:8089/geoserver/aegisgeoint/wfs',
        {
          params: {
            service: 'WFS',
            version: '1.0.0',
            request: 'GetFeature',
            typeName: 'aegisgeoint:papua_sensors',
            outputFormat: 'application/json'
          },
          timeout: 10000
        }
      );
      setSensors(sensorsRes.data.features || []);
      
      setLoading(false);
    } catch (error) {
      console.error('Error fetching WFS data:', error);
      setError('Failed to load map data');
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchData();
    const interval = setInterval(fetchData, 15000);
    return () => clearInterval(interval);
  }, []);

  // Basemap options for UI
  const basemapOptions = [
    { id: 'satellite', label: '🛰️ Satellite', icon: '🌍' },
    { id: 'googleSatellite', label: '🗺️ Google Satellite', icon: '📸' },
    { id: 'hybrid', label: '🔀 Hybrid', icon: '🏷️' },
    { id: 'dark', label: '🌙 Dark Mode', icon: '🌙' },
    { id: 'osm', label: '🗺️ OSM', icon: '📍' }
  ];

  if (loading) {
    return (
      <div className="map-loading">
        <img src={logoUrl} alt="Loading" style={{ width: 80, height: 80 }} />
        <p>Loading Map Data...</p>
        <style>{styles}</style>
      </div>
    );
  }

  if (error) {
    return (
      <div className="map-error">
        <div className="error-icon">⚠️</div>
        <p>{error}</p>
        <button onClick={fetchData}>Retry</button>
        <style>{styles}</style>
      </div>
    );
  }

  const currentBasemap = BASEMAPS[basemap] || BASEMAPS.satellite;

  return (
    <div className="aegis-map-container">
      <style>{styles}</style>
      
      {/* Map Header */}
      <div className="map-header">
        <img src={logoUrl} alt="AegisGEOINT" className="map-logo" />
        <span className="map-title">AegisGEOINT Tactical Map</span>
        <span className="map-status online">● LIVE</span>
        
        {/* Basemap Selector */}
        <div className="basemap-selector">
          <button className="basemap-toggle">
            {basemapOptions.find(b => b.id === basemap)?.icon || '🗺️'}
          </button>
          <div className="basemap-dropdown">
            {basemapOptions.map((option) => (
              <button
                key={option.id}
                className={`basemap-option ${basemap === option.id ? 'active' : ''}`}
                onClick={() => setBasemap(option.id)}
              >
                <span>{option.icon}</span>
                {option.label}
              </button>
            ))}
          </div>
        </div>
      </div>
      
      <MapContainer
        center={mapCenter}
        zoom={mapZoom}
        style={{ height: '550px', width: '100%', borderRadius: '0 0 8px 8px' }}
        zoomControl={false}
      >
        <ZoomControl position="topright" />

        {/* Base Map - Selected by user */}
        <TileLayer
          url={currentBasemap.url}
          attribution={currentBasemap.attribution}
        />

        {/* GeoServer WMS - Restricted Zones */}
        <WMSTileLayer
          url="http://localhost:8089/geoserver/aegisgeoint/wms"
          layers="aegisgeoint:papua_restricted_zones"
          format="image/png"
          transparent={true}
          version="1.1.0"
          opacity={0.35}
        />

        {/* GeoServer WMS - Threat Events */}
        <WMSTileLayer
          url="http://localhost:8089/geoserver/aegisgeoint/wms"
          layers="aegisgeoint:papua_threat_events"
          format="image/png"
          transparent={true}
          version="1.1.0"
          opacity={0.6}
        />

        {/* Sensors */}
        {sensors.map((feature) => {
          const props = feature.properties;
          if (!props || !feature.geometry) return null;
          
          const coords = feature.geometry.coordinates;
          if (!coords || coords.length < 2) return null;

          return (
            <Marker
              key={`sensor-${props.id}`}
              position={[coords[1], coords[0]]}
              icon={sensorIcon}
            >
              <Popup>
                <div className="popup-content">
                  <h4 style={{ margin: '0 0 8px 0', color: '#4fc3f7' }}>
                    📡 {props.sensor_name || 'Sensor'}
                  </h4>
                  <table style={{ fontSize: '13px', width: '100%' }}>
                    <tbody>
                      <tr>
                        <td style={{ color: '#8899aa' }}>Type:</td>
                        <td>{props.sensor_type || 'N/A'}</td>
                      </tr>
                      <tr>
                        <td style={{ color: '#8899aa' }}>Status:</td>
                        <td style={{ color: '#22c55e' }}>{props.status || 'active'}</td>
                      </tr>
                      <tr>
                        <td style={{ color: '#8899aa' }}>Sector:</td>
                        <td>{props.sector || 'N/A'}</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </Popup>
            </Marker>
          );
        })}

        {/* Tracked Objects */}
        {trackedObjects.map((feature) => {
          const props = feature.properties;
          if (!props || !feature.geometry) return null;
          
          const coords = feature.geometry.coordinates;
          if (!coords || coords.length < 2) return null;

          const threatLevel = props.threat_level || 'LOW';
          const isDrone = props.object_type === 'DRONE' || props.object_type === 'drone';
          
          let droneStatus = 'active';
          if (threatLevel === 'HIGH' || threatLevel === 'CRITICAL') droneStatus = 'critical';
          else if (threatLevel === 'MEDIUM') droneStatus = 'warning';
          
          return (
            <Marker
              key={props.id || props.object_id}
              position={[coords[1], coords[0]]}
              icon={isDrone ? createDroneIcon(droneStatus) : getThreatIcon(threatLevel)}
            >
              <Popup>
                <div className="popup-content">
                  <div style={{ display: 'flex', alignItems: 'center', gap: '8px', marginBottom: '8px' }}>
                    {isDrone && <img src={droneIconUrl} style={{ width: 24, height: 24 }} alt="drone" />}
                    <h3 style={{ 
                      margin: 0,
                      color: isDrone ? '#4fc3f7' : '#ef4444',
                      fontSize: '16px'
                    }}>
                      {props.object_id || props.object_type || 'Unknown'}
                    </h3>
                  </div>
                  <table style={{ fontSize: '13px', width: '100%', borderCollapse: 'collapse' }}>
                    <tbody>
                      <tr>
                        <td style={{ padding: '2px 8px 2px 0', color: '#8899aa' }}>Type:</td>
                        <td style={{ padding: '2px 0', fontWeight: '500' }}>{props.object_type || 'N/A'}</td>
                      </tr>
                      <tr>
                        <td style={{ padding: '2px 8px 2px 0', color: '#8899aa' }}>Threat:</td>
                        <td style={{ 
                          padding: '2px 0', 
                          fontWeight: 'bold',
                          color: threatLevel === 'HIGH' || threatLevel === 'CRITICAL' ? '#ef4444' :
                            threatLevel === 'MEDIUM' ? '#f59e0b' : '#22c55e'
                        }}>
                          {threatLevel}
                        </td>
                      </tr>
                      <tr>
                        <td style={{ padding: '2px 8px 2px 0', color: '#8899aa' }}>Speed:</td>
                        <td style={{ padding: '2px 0' }}>{props.speed || 0} km/h</td>
                      </tr>
                      <tr>
                        <td style={{ padding: '2px 8px 2px 0', color: '#8899aa' }}>Sector:</td>
                        <td style={{ padding: '2px 0' }}>{props.sector || 'N/A'}</td>
                      </tr>
                      <tr>
                        <td style={{ padding: '2px 8px 2px 0', color: '#8899aa' }}>Confidence:</td>
                        <td style={{ padding: '2px 0' }}>
                          {props.confidence_score ? (props.confidence_score * 100).toFixed(0) + '%' : 'N/A'}
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </Popup>
            </Marker>
          );
        })}
      </MapContainer>

      {/* Legend */}
      <div className="map-legend">
        <div className="legend-title">LEGEND</div>
        <div className="legend-item">
          <img src={droneIconUrl} style={{ width: 20, height: 20 }} alt="drone" />
          <span>Drone</span>
        </div>
        <div className="legend-item">
          <span className="legend-dot threat-high"></span>
          <span>High Threat</span>
        </div>
        <div className="legend-item">
          <span className="legend-dot threat-medium"></span>
          <span>Medium Threat</span>
        </div>
        <div className="legend-item">
          <span className="legend-dot threat-low"></span>
          <span>Low Threat</span>
        </div>
        <div className="legend-item">
          <span className="legend-dot sensor"></span>
          <span>Sensor</span>
        </div>
        <div className="legend-item">
          <span className="legend-dot geofence"></span>
          <span>Restricted Zone</span>
        </div>
      </div>

      <style jsx>{`
        .aegis-map-container {
          position: relative;
          width: 100%;
        }

        .map-header {
          display: flex;
          align-items: center;
          gap: 12px;
          padding: 10px 16px;
          background: rgba(10, 14, 26, 0.95);
          border-radius: 8px 8px 0 0;
          border: 1px solid rgba(255,255,255,0.06);
          border-bottom: none;
          flex-wrap: wrap;
        }

        .map-logo {
          height: 32px;
          width: auto;
        }

        .map-title {
          font-size: 14px;
          font-weight: 600;
          color: #e0e8f0;
          flex: 1;
        }

        .map-status {
          font-size: 12px;
          font-weight: 500;
          padding: 4px 12px;
          border-radius: 12px;
        }

        .map-status.online {
          color: #22c55e;
          background: rgba(34, 197, 94, 0.15);
        }

        /* ========================================
           BASEMAP SELECTOR
           ======================================== */
        .basemap-selector {
          position: relative;
          display: inline-block;
        }

        .basemap-toggle {
          padding: 4px 12px;
          background: rgba(79, 195, 247, 0.15);
          border: 1px solid rgba(79, 195, 247, 0.2);
          border-radius: 6px;
          color: #e0e8f0;
          cursor: pointer;
          font-size: 18px;
          transition: all 0.3s ease;
        }

        .basemap-toggle:hover {
          background: rgba(79, 195, 247, 0.25);
        }

        .basemap-dropdown {
          display: none;
          position: absolute;
          top: 100%;
          right: 0;
          margin-top: 4px;
          background: rgba(10, 14, 26, 0.98);
          backdrop-filter: blur(10px);
          border: 1px solid rgba(255,255,255,0.06);
          border-radius: 8px;
          padding: 6px;
          min-width: 160px;
          box-shadow: 0 8px 30px rgba(0,0,0,0.5);
          z-index: 1000;
        }

        .basemap-selector:hover .basemap-dropdown {
          display: block;
        }

        .basemap-option {
          display: flex;
          align-items: center;
          gap: 8px;
          width: 100%;
          padding: 6px 12px;
          background: transparent;
          border: none;
          border-radius: 4px;
          color: #e0e8f0;
          cursor: pointer;
          font-size: 13px;
          transition: all 0.2s ease;
        }

        .basemap-option:hover {
          background: rgba(79, 195, 247, 0.1);
        }

        .basemap-option.active {
          background: rgba(79, 195, 247, 0.15);
          color: #4fc3f7;
        }

        .basemap-option span {
          font-size: 16px;
        }

        .map-loading, .map-error {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          height: 500px;
          background: rgba(255,255,255,0.03);
          border-radius: 8px;
          color: #8899aa;
        }

        .map-loading p {
          margin-top: 12px;
        }

        .map-error button {
          margin-top: 12px;
          padding: 8px 20px;
          background: rgba(79, 195, 247, 0.15);
          border: 1px solid rgba(79, 195, 247, 0.2);
          border-radius: 6px;
          color: #4fc3f7;
          cursor: pointer;
        }

        .map-error button:hover {
          background: rgba(79, 195, 247, 0.25);
        }

        .map-legend {
          position: absolute;
          bottom: 20px;
          left: 20px;
          z-index: 1000;
          background: rgba(10, 14, 26, 0.92);
          backdrop-filter: blur(10px);
          padding: 10px 14px;
          border-radius: 8px;
          border: 1px solid rgba(255,255,255,0.06);
          display: flex;
          flex-direction: column;
          gap: 4px;
          min-width: 120px;
        }

        .legend-title {
          font-size: 10px;
          font-weight: 600;
          text-transform: uppercase;
          letter-spacing: 1px;
          color: #8899aa;
          margin-bottom: 4px;
        }

        .legend-item {
          display: flex;
          align-items: center;
          gap: 8px;
          font-size: 12px;
          color: #e0e8f0;
        }

        .legend-dot {
          width: 10px;
          height: 10px;
          border-radius: 50%;
          border: 1px solid rgba(255,255,255,0.2);
          flex-shrink: 0;
        }

        .legend-dot.threat-high {
          background: #ef4444;
        }

        .legend-dot.threat-medium {
          background: #f59e0b;
        }

        .legend-dot.threat-low {
          background: #22c55e;
        }

        .legend-dot.sensor {
          background: #4fc3f7;
          border-color: #4fc3f7;
        }

        .legend-dot.geofence {
          background: transparent;
          border: 2px dashed #ef4444;
          width: 14px;
          height: 10px;
          border-radius: 2px;
        }

        .popup-content {
          min-width: 200px;
        }

        .popup-content table {
          border-collapse: collapse;
        }

        .popup-content tr {
          border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .popup-content tr:last-child {
          border-bottom: none;
        }

        /* Leaflet popup custom styles */
        :global(.leaflet-popup-content-wrapper) {
          background: #1a1f33 !important;
          color: #e0e8f0 !important;
          border-radius: 8px !important;
          border: 1px solid rgba(255,255,255,0.06) !important;
          box-shadow: 0 4px 20px rgba(0,0,0,0.5) !important;
        }

        :global(.leaflet-popup-tip) {
          background: #1a1f33 !important;
        }

        :global(.leaflet-control-zoom a) {
          background: #1a1f33 !important;
          color: #e0e8f0 !important;
          border-color: rgba(255,255,255,0.06) !important;
        }

        :global(.leaflet-control-zoom a:hover) {
          background: rgba(255,255,255,0.05) !important;
        }

        @media (max-width: 768px) {
          .map-header {
            gap: 8px;
          }
          
          .map-title {
            font-size: 12px;
          }
          
          .basemap-dropdown {
            right: -40px;
          }
        }
      `}</style>
    </div>
  );
};

export default AegisMap;
